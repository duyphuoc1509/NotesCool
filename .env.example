# ─── Internal Database ──────────────────────────────────────
# PostgreSQL connection components for the internal database.
# The backend reads these via the Database:Internal:* configuration section
# or directly as environment variables (DATABASE_INTERNAL_*).
DATABASE_INTERNAL_HOST=postgres
DATABASE_INTERNAL_PORT=5432
DATABASE_INTERNAL_NAME=notescool
DATABASE_INTERNAL_USER=postgres
DATABASE_INTERNAL_PASSWORD=postgres

# ─── SSO ────────────────────────────────────────────────────
GOOGLE_SSO_ENABLED=true
GOOGLE_SSO_CLIENT_ID=
GOOGLE_SSO_CLIENT_SECRET=__SET_IN_ENV__
GOOGLE_SSO_REDIRECT_URL=http://localhost:10001/auth/callback/google

MICROSOFT_SSO_ENABLED=true
MICROSOFT_SSO_CLIENT_ID=
MICROSOFT_SSO_CLIENT_SECRET=***
MICROSOFT_SSO_REDIRECT_URL=https://note.tripschill.com/api/auth/sso/microsoft/callback
