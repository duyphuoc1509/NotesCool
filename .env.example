# NotesCool local/deployment environment template
# Copy to your deployment secret store or local .env file. Do not commit real secrets.

ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=postgres;Database=notescool;Username=postgres;Password=postgres

# SSO providers are disabled by default. Set Enabled=true only when every required
# value below is configured for the deployment environment.
Sso__Providers__0__Name=Google
Sso__Providers__0__Enabled=false
Sso__Providers__0__ClientId=
Sso__Providers__0__ClientSecret=__SET_IN_ENV__
Sso__Providers__0__Authority=https://accounts.google.com
Sso__Providers__0__CallbackPath=/signin-google
Sso__Providers__0__RedirectUrls__0=http://localhost:5173/auth/callback/google

Sso__Providers__1__Name=Microsoft
Sso__Providers__1__Enabled=false
Sso__Providers__1__ClientId=
Sso__Providers__1__ClientSecret=__SET_IN_ENV__
Sso__Providers__1__Authority=https://login.microsoftonline.com/common/v2.0
Sso__Providers__1__CallbackPath=/signin-microsoft
Sso__Providers__1__RedirectUrls__0=http://localhost:5173/auth/callback/microsoft
