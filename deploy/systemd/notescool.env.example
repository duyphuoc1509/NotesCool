# Copy this file to /etc/sysconfig/notescool on the CentOS 9 server.
# Do not commit the real values.

# ASP.NET Core runtime
ASPNETCORE_ENVIRONMENT=Production

# Internal database
DATABASE_INTERNAL_HOST=postgres
DATABASE_INTERNAL_PORT=5432
DATABASE_INTERNAL_NAME=notescool
DATABASE_INTERNAL_USER=postgres
DATABASE_INTERNAL_PASSWORD=change-me

# --- Google SSO ---
SSO_GOOGLE_ENABLED=true
SSO_GOOGLE_CLIENT_ID=change-me
SSO_GOOGLE_CLIENT_SECRET=change-me
# Authority is fixed in code; CALLBACK_PATH is informational only.
SSO_GOOGLE_CALLBACK_PATH=/signin-google
# OAuth redirect_uri sent to Google. MUST EXACTLY match the entry registered in
# Google Cloud Console (scheme included). Use this to avoid scheme mismatch
# (http vs https) when running behind a reverse proxy.
SSO_GOOGLE_REDIRECT_URI=https://your-domain.example/api/auth/sso/google/callback
# Frontend URLs the backend may redirect the browser back to after exchanging
# the OAuth code (carries ?provider=google&sessionCode=...). NOT the OAuth
# redirect_uri. Comma-separated list; first entry is used by default.
SSO_GOOGLE_REDIRECT_URLS=https://your-domain.example/auth/callback/google

# --- Microsoft SSO ---
SSO_MICROSOFT_ENABLED=false
SSO_MICROSOFT_CLIENT_ID=
SSO_MICROSOFT_CLIENT_SECRET=
SSO_MICROSOFT_CALLBACK_PATH=/signin-microsoft
SSO_MICROSOFT_REDIRECT_URI=https://your-domain.example/api/auth/sso/microsoft/callback
SSO_MICROSOFT_REDIRECT_URLS=https://your-domain.example/auth/callback/microsoft
